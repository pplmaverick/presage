# ============================================================
# arc-weather-market — 前端環境變數範本（Vite / React）
# 用途：WeatherBar 即時氣溫顯示
#
# 使用方式：
#   cp .env.example .env
#   填入真實數值後儲存
#   開發：npm run dev（Vite 會自動讀取 .env）
#   部署：在 Vercel Dashboard → Settings → Environment Variables 填入
#
# ⚠️  .env 已加入 .gitignore，禁止提交到 git
# ⚠️  Vite 只會將 VITE_ 開頭的變數暴露給瀏覽器端，
#     其他前綴的變數不會被打包進前端程式碼
# ============================================================


# ------------------------------------------------------------
# 🔑 VITE_OPENWEATHER_API_KEY
# OpenWeatherMap API 金鑰，用於 WeatherBar 元件顯示各城市即時氣溫
#
# 申請方式：
#   1. 前往 https://openweathermap.org/api
#   2. 註冊免費帳號
#   3. 進入 My API Keys 頁面複製 Default key
#   4. 免費方案支援每分鐘 60 次呼叫，足夠開發與測試使用
#
# 使用位置：frontend/src/components/WeatherBar.tsx
# API 端點：https://api.openweathermap.org/data/2.5/weather
#
# ⚠️  此 key 會被打包進前端 JS，不應使用付費方案的高權限 key
# ------------------------------------------------------------
VITE_OPENWEATHER_API_KEY=your_openweathermap_api_key_here


# ------------------------------------------------------------
# ℹ️  以下變數由系統自動注入，開發者「不需要」手動設定
# ------------------------------------------------------------

# VERCEL_OIDC_TOKEN
# Vercel 部署時自動注入的 OIDC 驗證 token（存於 .env.local）
# 本地開發不需要此變數，Vercel CI 環境會自動處理
# → 請勿手動填寫或提交此變數
