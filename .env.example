# ============================================================
# presage — 根目錄環境變數範本
# 用途：Hardhat 部署腳本 / Oracle 結算腳本
#
# 使用方式：
#   cp .env.example .env
#   填入真實數值後儲存
#
# ⚠️  .env 已加入 .gitignore，禁止提交到 git
# ============================================================


# ------------------------------------------------------------
# 🔑 PRIVATE_KEY
# 部署合約與執行所有腳本（lockMarket、submitResult 等）的錢包私鑰
#
# 格式：64 位十六進位字串，不含 0x 前綴
# 取得方式：MetaMask → 帳戶詳細資料 → 匯出私鑰
#
# ⚠️  請使用「測試專用錢包」，切勿使用存放大量資產的主錢包
# ⚠️  私鑰洩漏即代表錢包資產可被完全控制，務必保密
# ------------------------------------------------------------
PRIVATE_KEY=your_64_char_hex_private_key_without_0x_prefix


# ------------------------------------------------------------
# 📍 USDC_ADDRESS
# Arc Testnet 上的 USDC Precompile 合約地址
#
# Arc Testnet 固定值，一般不需要修改
# 參考：https://docs.arc.network/testnet/precompiles
# ------------------------------------------------------------
USDC_ADDRESS=0x3600000000000000000000000000000000000000


# ------------------------------------------------------------
# 📍 PHAROS_USDC_ADDRESS
# Pharos Testnet 上的 USDC 合約地址
#
# 用途：pharos 相關腳本（deploy-pharos.ts、e2e-pharos.ts 等）
# 與 Arc Testnet 的 USDC 地址不同，兩條鏈各自獨立
# 取得方式：Pharos 官方文件或部署後的合約地址
# ------------------------------------------------------------
PHAROS_USDC_ADDRESS=0xYourPharosUsdcContractAddressHere
